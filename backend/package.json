{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "kill -9 $(lsof -t -i:3060) || true; nodemon src/index.js --delay=2s --ignore 'data/*'",
        "withdraw": "node scripts/withdraw-funds.js",
        "withdraw:avax": "node scripts/withdraw-funds.js --asset AVAX",
        "withdraw:vka": "node scripts/withdraw-funds.js --asset VKA",
        "send:vka": "node scripts/send-vka.js",
        "sync:sponge-endpoints": "node scripts/sync-sponge-endpoints-from-manifest.js",
        "sync:sponge-endpoints:update": "node scripts/sync-sponge-endpoints-from-manifest.js --update-existing",
        "sync:sponge-endpoints:dry-run": "DRY_RUN=1 node scripts/sync-sponge-endpoints-from-manifest.js",
        "sponge:write-jobs": "node scripts/sync-sponge-endpoints-from-manifest.js --write-jobs",
        "sponge:http-bulk": "node scripts/sponge-http-bulk-create.js",
        "deploy:payment": "node scripts/deploy-payment-multichain.js",
        "deploy:payment:base": "node scripts/deploy-payment-multichain.js --chain base",
        "deploy:payment:xlayer": "node scripts/deploy-payment-multichain.js --chain xlayer",
        "deploy:payment:avalanche": "node scripts/deploy-payment-multichain.js --chain avalanche",
        "deploy:payment:fuji": "node scripts/deploy-payment-multichain.js --chain avalanche-fuji",
        "discover:x402": "npx -y @agentcash/discovery@latest discover",
        "print:openapi": "node -e \"const m=require('./src/config/tools-manifest.json');const b=require('./src/utils/buildOpenApiFromManifest');const c=require('./src/config');console.log(JSON.stringify(b(m,{publicOrigin:c.publicOrigin}),null,2))\""
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@koa/cors": "^5.0.0",
        "@koa/router": "^15.0.0",
        "axios": "^1.13.2",
        "dotenv": "^17.2.3",
        "ethers": "^6.16.0",
        "jsonwebtoken": "^9.0.3",
        "koa": "^3.1.1",
        "koa-body": "^7.0.0",
        "koa-mount": "^4.2.0",
        "koa-static": "^5.0.0",
        "mime-types": "^3.0.2"
    },
    "devDependencies": {
        "bip39": "^3.1.0",
        "nodemon": "^3.1.11",
        "solc": "^0.8.31"
    }
}
